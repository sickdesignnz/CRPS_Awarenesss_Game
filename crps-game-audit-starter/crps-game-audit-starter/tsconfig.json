{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": [
      "vitest/importMeta"
    ]
  },
  "include": [
    "src",
    "tests",
    "vite.config.ts"
  ]
}